# Copy to .env and fill in. NEVER commit .env.

# App
APP_SECRET_KEY=change-me-to-a-long-random-string
APP_ENV=development            # development | production
BASE_URL=http://localhost:8000

# Database (Postgres / Supabase)
DATABASE_URL=postgresql://user:password@localhost:5432/steadybee

# Supabase (auth + storage), if used
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=     # server-side only — never expose to the browser

# Stripe (payments)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MOT_ANNUAL=       # price id for the annual MOT (test £99 vs £150)

# Email (newsletter / nurture)
EMAIL_API_KEY=
EMAIL_FROM=hello@steadybee.co.uk

# Market data sources (cited: BoE, ONS, HMRC) — add as wired up
FRED_API_KEY=
